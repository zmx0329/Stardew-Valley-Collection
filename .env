# Supabase storage + database
SUPABASE_URL=https://vsqvowkdrgcjlrgyhptv.supabase.co/
SUPABASE_KEY=
SUPABASE_BUCKET=artworks
SUPABASE_TABLE=artworks

# Local fallback (used when the above credentials are missing)
